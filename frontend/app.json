{
  "expo": {
    "name": "ForensicTimeline",
    "slug": "ForensicTimeline",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.alira.forensictimeline",
      "supportsTablet": true
    },
    "android": {
      "package": "com.alira.forensictimeline",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "experiments": {
      "baseUrl": "/forensic-timeline-reconstructor"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ae52fd02-005d-41b9-8a28-ab32598c4872"
      }
    },
    "plugins": [
      "@clerk/expo",
      "expo-secure-store"
    ]
  }
}
