PORT=5000

# Use a shared MongoDB Atlas URI if other people need to run the project
# while your laptop is off. Do not commit your real .env file.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/forensic_timeline?retryWrites=true&w=majority

JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret

PYTHON_PATH=python
UPLOAD_DIR=uploads
EXTRACTION_TIMEOUT=120000

# Development email behavior. Set to true when SMTP is not configured.
DEV_EMAIL_LOG=true
RESET_PASSWORD_URL=http://localhost:8081/reset-password

# Optional SMTP config for real email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Email validation settings.
ENFORCE_EMAIL_DOMAIN_CHECKS=true
ALLOWED_EMAIL_DOMAINS=gmail.com,outlook.com,hotmail.com,yahoo.com,icloud.com,proton.me,protonmail.com

# Optional AI config. Groq has a free tier; OpenAI requires credits.
AI_PROVIDER=groq
GROQ_API_KEY=
AI_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
